rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: posts
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - imageUrl: string (required)
    //   - category: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: settings
    // Document ID: site
    // Fields:
    //   - heroTitle: string
    //   - heroSubtitle: string
    //   - contactEmail: string
    //   - contactPhone: string
    //   - address: string
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "fkgks98@gmail.com" && request.auth.token.email_verified == true);
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
